  <property name="windowTitle">
   <string>LENS - Loss-prevention Event Notification System</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
* {
    font-family: "Segoe UI", "Inter", "Helvetica Neue", Arial, sans-serif;
}

QMainWindow {
    background-color: #070d1a;
}

QWidget#centralwidget {
    background-color: #070d1a;
    color: #e2e8f0;
}

/* ── SIDEBAR ──────────────────────────────── */
QFrame#sidebarFrame {
    background-color: #0b1220;
    border-right: 1px solid #1a2540;
}

QLabel#appTitleLabel {
    color: #f8fafc;
    font-size: 26px;
    font-weight: 700;
    letter-spacing: 3px;
}

QLabel#appSubtitleLabel {
    color: #475569;
    font-size: 10px;
    letter-spacing: 0.3px;
}

QFrame#sidebarDivider {
    background-color: #1a2540;
    max-height: 1px;
    min-height: 1px;
}

QPushButton#liveCamerasButton,
QPushButton#incidentsButton,
QPushButton#settingsButton {
    background-color: transparent;
    color: #64748b;
    border: none;
    border-radius: 8px;
    padding: 11px 14px;
    text-align: left;
    font-size: 14px;
    font-weight: 500;
}

QPushButton#liveCamerasButton:hover,
QPushButton#incidentsButton:hover,
QPushButton#settingsButton:hover {
    background-color: rgba(30, 41, 59, 0.7);
    color: #cbd5e1;
}

QPushButton[navActive="true"] {
    background-color: rgba(59, 130, 246, 0.12);
    color: #93c5fd;
    font-weight: 600;
    border: 1px solid rgba(59, 130, 246, 0.2);
}

QPushButton[navActive="true"]:hover {
    background-color: rgba(59, 130, 246, 0.2);
    color: #bfdbfe;
}

QLabel#systemStatusLabel {
    background-color: rgba(16, 185, 129, 0.1);
    color: #34d399;
    border: 1px solid rgba(16, 185, 129, 0.25);
    border-radius: 8px;
    padding: 5px 10px;
    font-weight: 600;
    font-size: 12px;
    qproperty-alignment: AlignCenter;
}

/* ── HEADER ───────────────────────────────── */
QFrame#headerFrame {
    background-color: #070d1a;
    border-bottom: 1px solid #1a2540;
}

QLabel#pageTitleLabel {
    color: #f8fafc;
    font-size: 22px;
    font-weight: 700;
}

QLabel#pageSubtitleLabel {
    color: #475569;
    font-size: 13px;
}

QLabel#detectionStatusBadge {
    background-color: rgba(16, 185, 129, 0.1);
    color: #34d399;
    border: 1px solid rgba(16, 185, 129, 0.28);
    border-radius: 20px;
    padding: 8px 18px;
    font-weight: 600;
    font-size: 13px;
}

/* ── CAMERA CARDS ─────────────────────────── */
QFrame#cameraCard1,
QFrame#cameraCard2,
QFrame#cameraCard3,
QFrame#cameraCard4 {
    background-color: #0d1424;
    border: 1px solid #1a2540;
    border-top: 2px solid #1e3a5f;
    border-radius: 12px;
}

QLabel#cameraTitleLabel1,
QLabel#cameraTitleLabel2,
QLabel#cameraTitleLabel3,
QLabel#cameraTitleLabel4 {
    color: #e2e8f0;
    font-size: 14px;
    font-weight: 600;
}

QLabel#cameraStatusLabel1,
QLabel#cameraStatusLabel2,
QLabel#cameraStatusLabel3,
QLabel#cameraStatusLabel4 {
    background-color: rgba(16, 185, 129, 0.1);
    color: #34d399;
    border: 1px solid rgba(16, 185, 129, 0.25);
    border-radius: 8px;
    padding: 3px 10px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.5px;
}

QLabel#cameraPlaceholder1,
QLabel#cameraPlaceholder2,
QLabel#cameraPlaceholder3,
QLabel#cameraPlaceholder4 {
    background-color: #030711;
    color: #1e3a5f;
    border-radius: 8px;
    border: 1px solid #111f35;
    font-size: 13px;
    font-weight: 500;
}

/* ── INCIDENTS PAGE ───────────────────────── */
QFrame#incidentPanel {
    background-color: #0d1424;
    border: 1px solid #1a2540;
    border-radius: 12px;
}

QLabel#incidentPanelTitle {
    color: #f8fafc;
    font-size: 17px;
    font-weight: 600;
}

QTableWidget#incidentsTable {
    background-color: #030711;
    color: #cbd5e1;
    border: 1px solid #1a2540;
    border-radius: 8px;
    gridline-color: #0d1a2e;
    selection-background-color: rgba(59, 130, 246, 0.18);
    selection-color: #93c5fd;
    outline: none;
}

QTableWidget#incidentsTable::item {
    padding: 10px 14px;
    border-bottom: 1px solid #0d1a2e;
}

QTableWidget#incidentsTable::item:selected {
    background-color: rgba(59, 130, 246, 0.18);
    color: #93c5fd;
}

QHeaderView {
    background-color: #0b1220;
    border: none;
}

QHeaderView::section {
    background-color: #0b1220;
    color: #64748b;
    border: none;
    border-bottom: 1px solid #1a2540;
    border-right: 1px solid #1a2540;
    padding: 10px 14px;
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.6px;
    text-transform: uppercase;
}

QHeaderView::section:last {
    border-right: none;
}

/* ── SCROLLBARS ───────────────────────────── */
QScrollBar:vertical {
    background: #0b1220;
    width: 7px;
    border-radius: 4px;
    margin: 0;
}

QScrollBar::handle:vertical {
    background: #1e3a5f;
    border-radius: 4px;
    min-height: 24px;
}

QScrollBar::handle:vertical:hover {
    background: #2563eb;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: none;
}

QScrollBar:horizontal {
    background: #0b1220;
    height: 7px;
    border-radius: 4px;
    margin: 0;
}

QScrollBar::handle:horizontal {
    background: #1e3a5f;
    border-radius: 4px;
    min-width: 24px;
}

QScrollBar::handle:horizontal:hover {
    background: #2563eb;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0px;
}

QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background: none;
}

/* ── STATUS BAR ───────────────────────────── */
QStatusBar {
    background-color: #0b1220;
    color: #334155;
    border-top: 1px solid #1a2540;
    font-size: 12px;
}

/* ── SETTINGS / CAMERA FORM ───────────────── */
QFrame#cameraListPanel,
QFrame#cameraFormPanel {
    background-color: #0d1424;
    border: 1px solid #1a2540;
    border-radius: 12px;
}

QLabel#cameraListTitle,
QLabel#cameraFormTitle {
    color: #f8fafc;
    font-size: 16px;
    font-weight: 600;
}

QLabel#labelCameraName,
QLabel#labelCameraUrl,
QLabel#labelCameraUsername,
QLabel#labelCameraPassword,
QLabel#labelCameraLocation {
    color: #475569;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.5px;
}

QLabel#cameraUrlHint {
    color: #1e3a5f;
    font-size: 11px;
}

QTableWidget#cameraConfigTable {
    background-color: #030711;
    color: #cbd5e1;
    border: 1px solid #1a2540;
    border-radius: 8px;
    gridline-color: #0d1a2e;
    selection-background-color: rgba(59, 130, 246, 0.18);
    selection-color: #93c5fd;
    outline: none;
}

QTableWidget#cameraConfigTable::item {
    padding: 10px 14px;
    border-bottom: 1px solid #0d1a2e;
}

QTableWidget#cameraConfigTable::item:selected {
    background-color: rgba(59, 130, 246, 0.18);
    color: #93c5fd;
}

QLineEdit {
    background-color: #0b1220;
    color: #e2e8f0;
    border: 1px solid #1a2540;
    border-radius: 8px;
    padding: 9px 12px;
    font-size: 13px;
    selection-background-color: rgba(59, 130, 246, 0.3);
}

QLineEdit:focus {
    border: 1px solid #3b82f6;
    background-color: #0d1830;
}

QLineEdit:disabled {
    color: #334155;
    border-color: #111f35;
}

QCheckBox {
    color: #94a3b8;
    font-size: 13px;
    spacing: 8px;
}

QCheckBox::indicator {
    width: 17px;
    height: 17px;
    border-radius: 5px;
    border: 1px solid #1a2540;
    background-color: #0b1220;
}

QCheckBox::indicator:checked {
    background-color: #2563eb;
    border-color: #3b82f6;
}

QCheckBox::indicator:hover {
    border-color: #3b82f6;
}

QPushButton#saveCameraButton {
    background-color: #2563eb;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    padding: 10px 20px;
    font-size: 13px;
    font-weight: 600;
}

QPushButton#saveCameraButton:hover {
    background-color: #3b82f6;
}

QPushButton#saveCameraButton:pressed {
    background-color: #1d4ed8;
}

QPushButton#cancelCameraButton {
    background-color: transparent;
    color: #64748b;
    border: 1px solid #1a2540;
    border-radius: 8px;
    padding: 10px 20px;
    font-size: 13px;
    font-weight: 500;
}

QPushButton#cancelCameraButton:hover {
    background-color: rgba(30, 41, 59, 0.6);
    color: #94a3b8;
    border-color: #334155;
}
