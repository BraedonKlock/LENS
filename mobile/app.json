{
  "expo": {
    "name": "LENS",
    "slug": "lens-monitor",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/lens_logo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#0D1117"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lens.monitor"
    },
    "android": {
      "package": "com.lens.monitor",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#FF4444"
        }
      ],
      "expo-asset",
      "expo-secure-store",
      "expo-video"
    ],
    "extra": {
      "eas": {
        "projectId": "8977e17d-8226-4494-a32c-83a57d2836cb"
      }
    },
    "owner": "braedonk"
  }
}
